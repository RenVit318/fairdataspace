# Dataspace Configuration
# Selects which dataspace (branding, default FDPs, text) this instance serves.
# Must match a directory name under dataspaces/ (e.g. humanitarian, africa).
DATASPACE=humanitarian

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# FDP Client Configuration
FDP_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Dashboard SPARQL credentials (for aggregate statistics)
# Create a restricted read-only user on your AllegroGraph instances for this
DASHBOARD_SPARQL_USERNAME=
DASHBOARD_SPARQL_PASSWORD=
DASHBOARD_REFRESH_INTERVAL=86400
